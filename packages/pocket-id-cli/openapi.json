        }
      }
    },
    "/api/user-groups/{id}/users": {
      "put": {
        "operationId": "update-group-members",
        "summary": "Update group members",
        "tags": ["User Groups"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
