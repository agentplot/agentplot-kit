        "tags": ["Users"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "User deleted" }
        }
      }
    },
    "/api/users/{id}/groups": {
      "get": {
        "operationId": "get-user-groups",
        "summary": "Get groups for a user",
        "tags": ["Users"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "User's groups",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/UserGroupMinimal" } }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}/user-groups": {
      "put": {
        "operationId": "update-user-groups",
