{
  "openapi": "3.0.3",
  "info": {
    "title": "Pocket ID Admin API",
    "description": "Self-hosted OIDC identity provider admin API. Reconstructed from source annotations at pocket-id/pocket-id commit 549b487.",
    "version": "2.0.0"
  },
  "servers": [],
  "security": [
    { "bearerAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key or JWT session token"
      }
    },
    "parameters": {
      "paginationPage": {
        "name": "pagination[page]",
        "in": "query",
        "schema": { "type": "integer", "default": 1 },
        "description": "Page number"
      },
      "paginationLimit": {
        "name": "pagination[limit]",
        "in": "query",
        "schema": { "type": "integer", "default": 20 },
        "description": "Items per page"
      },
      "sortColumn": {
        "name": "sort[column]",
        "in": "query",
        "schema": { "type": "string" },
        "description": "Column to sort by"
      },
      "sortDirection": {
        "name": "sort[direction]",
        "in": "query",
        "schema": { "type": "string", "enum": ["asc", "desc"] },
        "description": "Sort direction"
      },
      "search": {
        "name": "search",
        "in": "query",
        "schema": { "type": "string" },
        "description": "Search filter"
      }
    },
    "schemas": {
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": {} },
          "pagination": {
            "type": "object",
            "properties": {
              "page": { "type": "integer" },
              "limit": { "type": "integer" },
              "totalItems": { "type": "integer" },
              "totalPages": { "type": "integer" }
            }
          }
        }
      },
      "OidcClient": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "hasLogo": { "type": "boolean" },
          "hasDarkLogo": { "type": "boolean" },
          "launchURL": { "type": "string", "nullable": true },
          "requiresReauthentication": { "type": "boolean" },
          "callbackURLs": { "type": "array", "items": { "type": "string" } },
          "logoutCallbackURLs": { "type": "array", "items": { "type": "string" } },
          "isPublic": { "type": "boolean" },
          "pkceEnabled": { "type": "boolean" },
          "isGroupRestricted": { "type": "boolean" },
          "allowedUserGroups": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserGroupMinimal" }
          }
        }
      },
      "OidcClientCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "callbackURLs": { "type": "array", "items": { "type": "string" } },
          "logoutCallbackURLs": { "type": "array", "items": { "type": "string" } },
          "isPublic": { "type": "boolean" },
          "pkceEnabled": { "type": "boolean" },
          "requiresReauthentication": { "type": "boolean" },
          "launchURL": { "type": "string" },
          "isGroupRestricted": { "type": "boolean" }
        },
        "required": ["name", "callbackURLs"]
      },
      "OidcClientUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "callbackURLs": { "type": "array", "items": { "type": "string" } },
          "logoutCallbackURLs": { "type": "array", "items": { "type": "string" } },
          "isPublic": { "type": "boolean" },
          "pkceEnabled": { "type": "boolean" },
          "requiresReauthentication": { "type": "boolean" },
          "launchURL": { "type": "string" },
          "isGroupRestricted": { "type": "boolean" }
        }
      },
      "OidcClientSecret": {
        "type": "object",
        "properties": {
          "secret": { "type": "string" }
        }
      },
      "OidcClientMetaData": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "hasLogo": { "type": "boolean" },
          "hasDarkLogo": { "type": "boolean" }
        }
      },
      "UpdateAllowedUserGroups": {
        "type": "object",
        "properties": {
          "userGroupIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["userGroupIds"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string", "nullable": true },
          "emailVerified": { "type": "boolean" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string", "nullable": true },
          "displayName": { "type": "string" },
          "isAdmin": { "type": "boolean" },
          "locale": { "type": "string", "nullable": true },
          "disabled": { "type": "boolean" },
          "ldapId": { "type": "string", "nullable": true },
          "customClaims": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CustomClaim" }
          },
          "userGroups": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserGroupMinimal" }
          }
        }
      },
      "UserCreate": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "email": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "isAdmin": { "type": "boolean" },
          "locale": { "type": "string" },
          "disabled": { "type": "boolean" }
        },
        "required": ["username", "email", "firstName"]
      },
      "UserUpdateGroups": {
        "type": "object",
        "properties": {
          "userGroupIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["userGroupIds"]
      },
      "UserGroup": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "friendlyName": { "type": "string" },
          "name": { "type": "string" },
          "users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/User" }
          },
          "allowedOidcClients": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OidcClient" }
          },
          "customClaims": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CustomClaim" }
          }
        }
      },
      "UserGroupMinimal": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "friendlyName": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "UserGroupCreate": {
        "type": "object",
        "properties": {
          "friendlyName": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["friendlyName", "name"]
      },
      "UserGroupUpdateUsers": {
        "type": "object",
        "properties": {
          "userIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["userIds"]
      },
      "UserGroupUpdateAllowedClients": {
        "type": "object",
        "properties": {
          "oidcClientIds": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["oidcClientIds"]
      },
      "ApiKey": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ApiKeyCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["name", "expiresAt"]
      },
      "ApiKeyResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" },
          "token": { "type": "string", "description": "Raw API key token, shown only at creation time" }
        }
      },
      "ApiKeyRenew": {
        "type": "object",
        "properties": {
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["expiresAt"]
      },
      "CustomClaim": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "CustomClaimCreate": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        },
        "required": ["key", "value"]
      },
      "AppConfigVariable": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" },
          "type": { "type": "string" },
          "isPublic": { "type": "boolean" }
        }
      },
      "AppConfigUpdate": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Key-value pairs of configuration to update"
      },
      "AuditLog": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "event": { "type": "string" },
          "ipAddress": { "type": "string" },
          "country": { "type": "string" },
          "city": { "type": "string" },
          "userAgent": { "type": "string" },
          "userId": { "type": "string" },
          "username": { "type": "string" },
          "oidcClientId": { "type": "string" },
          "oidcClientName": { "type": "string" },
          "data": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "SignupToken": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "token": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "SignupTokenCreate": {
        "type": "object",
        "properties": {
          "expiresAt": { "type": "string", "format": "date-time" }
        },
        "required": ["expiresAt"]
      }
    }
  },
  "paths": {
    "/api/oidc/clients": {
      "get": {
        "operationId": "list-clients",
        "summary": "List OIDC clients",
        "tags": ["OIDC Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/paginationPage" },
          { "$ref": "#/components/parameters/paginationLimit" },
          { "$ref": "#/components/parameters/sortColumn" },
          { "$ref": "#/components/parameters/sortDirection" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of OIDC clients",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/PaginatedResponse" },
                    { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/OidcClient" } } } }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create-client",
        "summary": "Create an OIDC client",
        "tags": ["OIDC Clients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OidcClientCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OidcClient" } } }
          }
        }
      }
    },
    "/api/oidc/clients/{id}": {
      "get": {
        "operationId": "get-client",
        "summary": "Get an OIDC client",
        "tags": ["OIDC Clients"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Client details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OidcClient" } } }
          }
        }
      },
      "put": {
        "operationId": "update-client",
        "summary": "Update an OIDC client",
        "tags": ["OIDC Clients"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OidcClientUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated client",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OidcClient" } } }
          }
        }
      },
      "delete": {
        "operationId": "delete-client",
        "summary": "Delete an OIDC client",
        "tags": ["OIDC Clients"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Client deleted" }
        }
      }
    },
    "/api/oidc/clients/{id}/secret": {
      "post": {
        "operationId": "regenerate-client-secret",
        "summary": "Generate a new client secret",
        "tags": ["OIDC Clients"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "New secret",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OidcClientSecret" } } }
          }
        }
      }
    },
    "/api/oidc/clients/{id}/allowed-user-groups": {
      "put": {
        "operationId": "update-client-allowed-groups",
        "summary": "Update allowed user groups for a client",
        "tags": ["OIDC Clients"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAllowedUserGroups" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated client",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OidcClient" } } }
          }
        }
      }
    },
    "/api/oidc/clients/{id}/meta": {
      "get": {
        "operationId": "get-client-meta",
        "summary": "Get client metadata (public, no auth required)",
        "tags": ["OIDC Clients"],
        "security": [],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Client metadata",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OidcClientMetaData" } } }
          }
        }
      }
    },
