          }
        }
      },
      "put": {
        "operationId": "update-current-user",
        "summary": "Update current user profile",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserCreate" }
            }
          }
