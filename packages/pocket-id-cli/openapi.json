    "/api/user-groups/{id}": {
      "get": {
        "operationId": "get-group",
        "summary": "Get a user group",
        "tags": ["User Groups"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
